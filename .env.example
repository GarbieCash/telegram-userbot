# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Generate with `npm run login`, then paste the printed session string here.
# Keep this secret -- it grants full access to your Telegram account.
TELEGRAM_SESSION=

# Group username (no @), invite link, or numeric chat ID.
TELEGRAM_GROUP=my_group_username

# The two daily messages. MESSAGE_2 defaults to MESSAGE_1 if left blank.
MESSAGE_1=Good morning!
MESSAGE_2=Good evening!

# Cron expressions (minute hour * * *). Defaults below = 9:00 AM and 6:00 PM.
CRON_TIME_1=0 9 * * *
CRON_TIME_2=0 18 * * *

# IANA timezone name, e.g. America/New_York, Europe/London, Asia/Karachi.
# Falls back to TIMEZONE if TIMEZONE_1 / TIMEZONE_2 aren't set -- use those
# two if the messages should fire in different timezones from each other.
TIMEZONE=UTC
TIMEZONE_1=
TIMEZONE_2=

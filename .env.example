# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Generate with `npm run login`, then paste the printed session string here.
# Keep this secret -- it grants full access to your Telegram account.
TELEGRAM_SESSION=

# One or more groups: username (no @), invite link, or numeric chat ID.
# Separate multiple groups with commas.
TELEGRAM_GROUP=my_group_username,https://t.me/+abc123,-1001234567890

# Daily messages, one per session. Add as many sessions as you want --
# MESSAGE_1, MESSAGE_2, MESSAGE_3, MESSAGE_4, ... -- they must be numbered
# contiguously starting at 1 (the app stops looking at the first gap).
# MESSAGE_1 and MESSAGE_2 have built-in defaults if left blank; MESSAGE_3+
# are required once you add a CRON_TIME_n for them.
MESSAGE_1=Good morning!
MESSAGE_2=Good evening!
MESSAGE_3=
MESSAGE_4=

# Cron expressions (minute hour * * *), one per session. Defaults for
# sessions 1/2 = 9:00 AM and 6:00 PM. Sessions 3+ have no default.
CRON_TIME_1=0 9 * * *
CRON_TIME_2=0 18 * * *
CRON_TIME_3=
CRON_TIME_4=

# IANA timezone name per session, e.g. America/New_York, Europe/London,
# Asia/Karachi, Africa/Lagos. Falls back to TIMEZONE if TIMEZONE_n isn't set --
# use per-session timezones if messages should fire in different timezones.
TIMEZONE=UTC
TIMEZONE_1=
TIMEZONE_2=
TIMEZONE_3=
TIMEZONE_4=

# "Good morning" session -- separate from MESSAGE_n above. It has no message
# env var of its own: it rotates through pre-written English/Indonesian
# variants (src/messages.js) so the wording changes every day it fires.
CRON_TIME_MORNING=0 3 * * *
TIMEZONE_MORNING=

# Every message sent (all sessions) automatically goes out bilingual:
# 🇬🇧 English text
#
# 🇮🇩 Indonesian text
# The fixed sessions (MESSAGE_1-4) are translated once and matched by exact
# text in src/messages.js. If you change a MESSAGE_n value in Render without
# updating that file's translation, the bot logs a warning and sends
# English-only rather than show a mismatched translation.
